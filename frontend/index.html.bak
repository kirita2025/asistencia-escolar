<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Control de Asistencia</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="manifest" href="/manifest.json">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="app">
        <header class="header">
            <div class="status-bar">
                <span id="hora">--:--</span>
                <span id="modo-badge" class="modo-badge">🟡 Conectando...</span>
            </div>
            <h1>📚 Control de Asistencia</h1>
            <div class="fecha" id="fecha-display">Cargando...</div>
        </header>
        <div class="fecha-selector">
            <label>📅 Fecha de asistencia</label>
            <div class="fecha-row">
                <input type="date" id="fecha-input">
                <button class="btn-hoy" id="btn-hoy">Hoy</button>
            </div>
            <div class="solo-lectura" id="solo-lectura">👁️ Solo lectura</div>
        </div>
        <div class="filtros">
            <select id="grado"><option value="">Todos los grados</option></select>
            <select id="seccion"><option value="">Todas</option></select>
            <button class="btn-cargar" id="btn-cargar">Cargar</button>
        </div>
        <div class="contador">
            <div><span class="num presente" id="c-p">0</span><span class="label">Presentes</span></div>
            <div><span class="num ausente" id="c-a">0</span><span class="label">Ausentes</span></div>
            <div><span class="num tardanza" id="c-t">0</span><span class="label">Tardanzas</span></div>
            <div><span class="num justificado" id="c-j">0</span><span class="label">Justificado</span></div>
            <div><span class="num excursion" id="c-e">0</span><span class="label">Excursión</span></div>
            <div><span class="num pendiente" id="c-pend">0</span><span class="label">Pendientes</span></div>
        </div>
        <div class="lista" id="lista">
            <div class="loading">Seleccioná grado/sección y tocá "Cargar"</div>
        </div>
        <div class="acciones">
            <button class="btn-guardar" id="btn-guardar">💾 Guardar</button>
            <button class="btn-stats" id="btn-stats">📊 Stats</button>
        </div>
        <div class="toast" id="toast"></div>
        <div id="debug-log" style="position:fixed;bottom:80px;left:10px;right:10px;background:rgba(0,0,0,0.8);color:#0f0;font-family:monospace;font-size:10px;padding:8px;border-radius:8px;max-height:100px;overflow-y:auto;z-index:9999;display:none;"></div>
    </div>

    <script src="/app.js"></script>
</body>
</html>