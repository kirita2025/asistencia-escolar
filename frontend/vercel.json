{
  "routes": [
    { "src": "/style.css", "dest": "/style.css", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" } },
    { "src": "/app.js", "dest": "/app.js", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" } },
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/manifest.json", "dest": "/manifest.json", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/(.*)", "dest": "/index.html", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } }
  ]
}